# Public API prefix (browser). MUST stay same-origin as this app (path like below) so the
# Laravel session cookie from login is sent. Do not point at http://127.0.0.1:8000/api from
# a page on http://localhost:3000 — cookies will not attach and uploads will 401/419.
NEXT_PUBLIC_API_BASE_URL=/backend/api

# Origin of this Next app (server-side fetch when building absolute URLs).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Laravel base URL for server components and UploadThing (direct HTTP, not through Next).
LARAVEL_BACKEND_URL=http://127.0.0.1:8000